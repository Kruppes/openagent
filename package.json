{
  "name": "openagent",
  "version": "0.9.4",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "dev": "node scripts/dev.mjs",
    "dev:all": "node scripts/dev.mjs",
    "dev:backend": "npm run dev --workspace=packages/web-backend",
    "dev:frontend": "npm run dev --workspace=packages/web-frontend",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint packages/",
    "clean": "rm -rf packages/*/dist"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/adm-zip": "^0.5.8",
    "@types/bcrypt": "^6.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.6",
    "@types/js-yaml": "^4.0.9",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.0.0",
    "@types/ws": "^8.18.1",
    "eslint": "^9.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^3.2.4"
  }
}
